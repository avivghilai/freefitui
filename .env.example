# FreeFit API credentials (server-side only)
FREEFIT_TOKEN=
FREEFIT_PHONE=
FREEFIT_ID=
FREEFIT_BINID=

# Database — local dev uses Docker Postgres (docker compose up)
DATABASE_URL=postgresql://freefit:freefit_dev@localhost:5433/freefit

# Mapbox (public token, restricted by domain in production)
VITE_MAPBOX_TOKEN=
